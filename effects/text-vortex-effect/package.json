{
  "name": "text-vortex-effect",
  "version": "1.0.0",
  "description": "文字旋涡特效 - 由中心向外旋转散开的震撼3D旋涡效果",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts TextVortex out/video.mp4 --chromium-flags=\"--headless=new\"",
    "render": "remotion render src/index.ts TextVortex out/video.mp4 --chromium-flags=\"--headless=new\""
  },
  "dependencies": {
    "@remotion/player": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
